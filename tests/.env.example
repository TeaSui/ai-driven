# Test Environment Variables
# Copy this file to .env and fill in real values before running tests.
# Lines marked [required] must be set; others have sensible defaults.

# ── Jira Configuration [required] ────────────────────────────────────────────
TEST_JIRA_URL=https://your-domain.atlassian.net
TEST_JIRA_EMAIL=your-email@example.com
TEST_JIRA_TOKEN=your-jira-api-token
TEST_JIRA_TICKET_ID=TEST-001
TEST_JIRA_PROJECT=TEST

# ── GitHub Configuration [required for Live E2E round-trip tests] ─────────────
# The repo must be the one configured in MCP_SERVERS_CONFIG as the github entry.
# Personal access token scopes: repo (read+write contents, pull_requests).
TEST_GITHUB_OWNER=your-github-org-or-user
TEST_GITHUB_REPO=your-test-repo
TEST_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── AWS Configuration [required for Live E2E round-trip tests] ────────────────
AWS_REGION=us-east-1
TEST_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:ai-driven-workflow
TEST_DYNAMODB_TABLE=ai-driven-state
TEST_CLAUDE_MODEL=claude-3-haiku-20240307

# ── Bitbucket Configuration [legacy — bitbucket integration tests only] ────────
TEST_BB_WORKSPACE=your-workspace
TEST_BB_REPO=your-test-repo
TEST_BB_USERNAME=your-username
TEST_BB_PASSWORD=your-app-password
TEST_BB_REPO_URL=https://bitbucket.org/your-workspace/your-test-repo.git

# ── Test Runner Knobs ─────────────────────────────────────────────────────────
# TEST_TIMEOUT: default Jest timeout in ms (live E2E tests override per-test)
TEST_TIMEOUT=30000
TEST_RETRY_ATTEMPTS=3
# Set TEST_CLEANUP=false to preserve Jira tickets / GitHub branches for debugging
TEST_CLEANUP=true
