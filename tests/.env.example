# Test Environment Variables

# Jira Configuration
TEST_JIRA_URL=https://your-domain.atlassian.net
TEST_JIRA_EMAIL=your-email@example.com
TEST_JIRA_TOKEN=your-jira-api-token
TEST_JIRA_TICKET_ID=TEST-001
TEST_JIRA_PROJECT=TEST

# Bitbucket Configuration
TEST_BB_WORKSPACE=your-workspace
TEST_BB_REPO=your-test-repo
TEST_BB_USERNAME=your-username
TEST_BB_PASSWORD=your-app-password
TEST_BB_REPO_URL=https://bitbucket.org/your-workspace/your-test-repo.git

# AWS Configuration
AWS_REGION=us-east-1
TEST_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:ai-driven-workflow
TEST_DYNAMODB_TABLE=ai-driven-state
TEST_CLAUDE_MODEL=claude-3-haiku-20240307

# Test Configuration
TEST_TIMEOUT=30000
TEST_RETRY_ATTEMPTS=3
TEST_CLEANUP=true
