{
    "name": "ai-driven-tests",
    "version": "1.0.0",
    "description": "End-to-end workflow automation tests for AI-driven code generation system",
    "scripts": {
        "test": "jest",
        "test:unit": "jest --testPathPattern=unit",
        "test:integration": "jest --testPathPattern=integration",
        "test:e2e": "jest --testPathPattern=e2e",
        "test:workflow": "jest --testPathPattern=workflow-integration",
        "test:coverage": "jest --coverage",
        "test:watch": "jest --watch",
        "test:ci": "jest --ci --coverage --maxWorkers=2"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.10.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "typescript": "~5.3.0",
        "nock": "^13.5.0",
        "dotenv": "^16.0.0"
    },
    "dependencies": {
        "@aws-sdk/client-sfn": "^3.0.0",
        "@aws-sdk/client-dynamodb": "^3.0.0",
        "axios": "^1.6.0"
    }
}