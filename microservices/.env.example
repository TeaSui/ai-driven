# ─── Application ──────────────────────────────────────────────
NODE_ENV=development

# ─── Security ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Message Broker ───────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# ─── Auth Service DB ──────────────────────────────────────────
AUTH_DB_USER=auth_user
AUTH_DB_PASS=auth_pass

# ─── Workflow Service DB ───────────────────────────────────────
WORKFLOW_DB_USER=workflow_user
WORKFLOW_DB_PASS=workflow_pass

# ─── Integration Service DB ───────────────────────────────────
INTEGRATION_DB_USER=integration_user
INTEGRATION_DB_PASS=integration_pass

# ─── Notification Service DB ──────────────────────────────────
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASS=notification_pass

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourcompany.com
