{
  "name": "@crm/notification-service",
  "version": "1.0.0",
  "description": "Notification delivery service (email, Slack, webhooks)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^5.6.0",
    "ioredis": "^5.3.2",
    "amqplib": "^0.10.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "express-async-errors": "^3.1.1",
    "nodemailer": "^6.9.7",
    "handlebars": "^4.7.8",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "jest": "^29.5.0",
    "prisma": "^5.6.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.16",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.ts", "**/*.test.ts"]
  }
}
